{
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devPath": "src/ui",
    "distDir": "src/ui",
    "withGlobalTauri": true
  },
  "package": {
    "productName": "quick-serve",
    "version": "0.2.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      }
    },
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "com.tauri.dev",
      "icon": [
        "src/ui/icons/32x32.png",
        "src/ui/icons/16x16.png",
        "src/ui/icons/96x96.png"
      ]
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "fullscreen": false,
        "resizable": true,
        "title": "quick-serve",
        "width": 500,
        "height": 700
      }
    ]
  }
}
